{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "NEXT_PUBLIC_API_URL",
        "API_GATEWAY_INTERNAL_URL",
        "NEXT_PUBLIC_PASSWORD_MIN_LENGTH",
        "NEXT_PUBLIC_AUTH_URL",
        "NEXT_PUBLIC_LMS_URL",
        "NEXT_PUBLIC_HR_URL",
        "NEXT_PUBLIC_TASK_URL"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "//#depcruise": {
      "inputs": ["packages/**/src/**", "services/**/src/**", "apps/**/src/**", ".dependency-cruiser.cjs"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
