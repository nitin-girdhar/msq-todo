# tasks-service — required environment variables
DATABASE_URL=postgres://task_svc:TaskSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm
# Tenant-dashboard pool: withRoleTx routes tenant_admin requests here. Without it
# every tenant_admin request throws at first use (Issue #1).
DATABASE_URL_TENANT=postgres://tenant_dash_svc:TenantSvc_Dev2025@localhost:5432/crm
# task_svc can read/write only the task schema + read-only iam/entity/geo (D8) —
# tells @platform/db to skip SET ROLE app_user, which would undo that isolation.
DB_PRODUCT_SCOPED_LOGIN=true
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string
TASKS_SERVICE_PORT=4008
NODE_ENV=development
