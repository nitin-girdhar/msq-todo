# todo-web (Next.js, todo.app.com) — required environment variables
NEXT_PUBLIC_API_URL=http://localhost:4000
API_GATEWAY_INTERNAL_URL=http://localhost:4000
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_PUBLIC_KEY=   # RS256 verification; falls back to JWT_SECRET (HS256) when unset
# JWT_KID=

# SSO: unauthenticated users bounce to NEXT_PUBLIC_AUTH_URL/login; the product
# switcher links to the sibling origins. Leave COOKIE_DOMAIN unset for
# single-host local dev.
COOKIE_SECURE=false
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_LMS_URL=http://localhost:3001
NEXT_PUBLIC_HR_URL=http://localhost:3002
NEXT_PUBLIC_TASK_URL=http://localhost:3003
