meta {
  name: Create Campaign-Statuses
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/lookups/campaign-statuses?tenant_id={{tenantId}}
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "name": "paused",
    "label": "Paused",
    "description": "Campaign temporarily paused"
  }
}
