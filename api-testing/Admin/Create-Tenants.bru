meta {
  name: Create Tenants
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/lookups/tenants
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "name": "acme-fitness",
    "domain_id": "{{tenantDomainId}}",
    "plan_type_id": "{{tenantPlanTypeId}}"
  }
}
