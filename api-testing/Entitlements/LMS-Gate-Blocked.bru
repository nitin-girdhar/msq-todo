meta {
  name: LMS Gate - Blocked (403)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/leads
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Gate rejection at the gateway. Precondition: deactivate the acting tenant's
  `lms` entitlement, e.g.

    UPDATE entity.tenant_modules SET is_active = false
    WHERE module = 'lms'
      AND tenant_id = (SELECT tenant_id FROM entity.organizations WHERE id = '<orgId>');

  The gateway productGuard now maps /leads -> product 'lms', finds it inactive,
  and returns 403 PRODUCT_NOT_ENABLED before proxying. (Re-enable afterwards.)
  A call made directly to leads-service instead — bypassing the gateway — is
  independently rejected 403 MODULE_NOT_ENABLED by requireModule('lms').
}

assert {
  res.status: eq 403
  res.body.error: eq PRODUCT_NOT_ENABLED
  res.body.product: eq lms
}
