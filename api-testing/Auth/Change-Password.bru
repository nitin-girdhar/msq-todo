meta {
  name: Change Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/auth/change-password
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "current_password": "Admin@123",
    "new_password": "NewAdmin@123"
  }
}

docs {
  Issues a fresh session cookie AND revokes all previously issued sessions for
  the user (other devices / stolen tokens) effective at the new token's iat.
  The returned session stays valid; older ones are rejected everywhere.
}
