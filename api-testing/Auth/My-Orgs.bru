meta {
  name: My Orgs
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/auth/my-orgs
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.orgs.length > 1) {
    // Stash a non-current org so Switch-Org.bru has a target to switch to.
    const current = bru.getVar("orgId");
    const other = res.body.data.orgs.find(o => o.org_id !== current);
    if (other) bru.setVar("switchOrgId", other.org_id);
  }
}

docs {
  Lists every branch the session user can act in — one entry per active
  iam.user_org_mapping row (plus the home org for legacy users without a
  mapping row), each with the role held in that branch.
}
