meta {
  name: Switch Org
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/auth/switch-org
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "org_id": "{{switchOrgId}}"
  }
}

script:post-response {
  if (res.status === 200) {
    const cookies = res.headers['set-cookie'];
    if (cookies) {
      const authCookie = cookies.find(c => c.startsWith('auth_token='));
      if (authCookie) {
        // The old token's jti is revoked server-side; keep the new one.
        const token = authCookie.split('=')[1].split(';')[0];
        bru.setVar("authToken", token);
      }
    }
    if (res.body.data && res.body.data.user) {
      bru.setVar("orgId", res.body.data.user.org_id);
    }
  }
}

docs {
  Re-mints the session for another branch the user is mapped to (run My-Orgs
  first to populate switchOrgId). The new JWT carries the role/rank the user
  holds in that branch via iam.user_org_mapping; the previous token is revoked.
  Responds 403 if the user has no active mapping for the requested org, and
  401 if the session cookie is missing/expired.
}
