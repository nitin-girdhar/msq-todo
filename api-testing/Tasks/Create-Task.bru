meta {
  name: Create Task
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "title": "Follow up with the lead",
    "description": "Call and confirm the demo slot",
    "list_id": "{{taskListId}}",
    "assignee_id": "{{assigneeUserId}}",
    "due_at": "2026-08-01T10:00:00Z",
    "priority_name": "high",
    "status_name": "todo",
    "related_entity_type": "lead",
    "related_entity_id": "{{leadId}}",
    "tags": ["vip"]
  }
}
