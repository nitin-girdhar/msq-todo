meta {
  name: Update User
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/users/{{userId}}
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "first_name": "Updated",
    "middle_name": "",
    "last_name": "Name",
    "email": "updated@example.com",
    "mobile": "9876543210",
    "role_name": "senior_sales_executive",
    "manager_id": null,
    "is_active": true,
    "force_password_change": false
  }
}
