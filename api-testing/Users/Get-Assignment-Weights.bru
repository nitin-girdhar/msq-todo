meta {
  name: Get Assignment Weights
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/users/assignment-weights
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Lists users eligible for auto lead assignment in the caller's org —
  active iam.user_org_mapping rows with role rank strictly between
  read_only (0) and org_admin (80) — along with their current
  lead_assignment_weight (0-100).

  Use this to review current weights before calling
  Update-Assignment-Weights.bru.
}
