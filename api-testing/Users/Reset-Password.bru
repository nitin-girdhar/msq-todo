meta {
  name: Reset User Password (Admin)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/users/{{userId}}/reset-password
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "new_password": "ResetPass@1234"
  }
}

docs {
  Revokes ALL of the target user's existing sessions immediately (jti-less
  user-scoped blocklist entry). After this call every previously issued token
  for that user is rejected by the gateway and /auth/me until they log in again.
}
