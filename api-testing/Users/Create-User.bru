meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "first_name": "Test",
    "middle_name": "",
    "last_name": "User",
    "email": "testuser@example.com",
    "role_name": "sales_executive",
    "mobile": "9876543210",
    "manager_id": "{{userId}}",
    "force_password_change": true
  }
}
