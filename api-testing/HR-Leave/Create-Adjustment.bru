meta {
  name: Create Adjustment
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/hr/leave/adjustments
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "user_id": "{{targetUserId}}",
    "leave_type_name": "{{leaveTypeName}}",
    "amount": 5,
    "note": "Opening balance credit"
  }
}
