meta {
  name: Preview Days
  type: http
  seq: 24
}

get {
  url: {{baseUrl}}/hr/leave/requests/preview?leave_type_name={{leaveTypeName}}&start_date=2026-08-10&end_date=2026-08-14&start_half=full&end_half=full
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Read-only working-days preview for the apply form. Reuses computeLeaveDays and
  the same validations as POST /hr/leave/requests but commits nothing — returns
  { days_count, balance, is_paid, allow_half_day, requires_document_after_days,
  max_consecutive_days, min_notice_days, sufficient, warnings } so the UI can show
  a live count and block submission client-side. The server still re-validates on
  apply.
}
