meta {
  name: Create Policy
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/hr/leave/policies
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "leave_type_name": "{{leaveTypeName}}",
    "org_id": "{{orgId}}",
    "accrual_frequency": "monthly",
    "accrual_amount": 1.5,
    "max_balance": 30,
    "carry_forward": true,
    "max_carry_forward": 10,
    "max_consecutive_days": 10,
    "min_notice_days": 1,
    "allow_half_day": true,
    "requires_document_after_days": 2,
    "approval_levels": 1,
    "applicable_from": "2026-04-01"
  }
}
