meta {
  name: Send WhatsApp Template Message
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/communications/whatsapp/template
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "phone_numbers": ["+919876543210"],
    "template_name": "your_template_name",
    "language_code": "en",
    "header_values": ["Header Value 1"],
    "body_values": ["Body Param 1", "Body Param 2"],
    "button_values": {}
  }
}
