meta {
  name: Send Email
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/communications/email
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "subject": "Test Email from CRM",
    "body": "Hello,\n\nThis is a test email sent from the CRM communication service.\n\nRegards,\nCRM Team",
    "email_addresses": ["recipient@example.com"],
    "cc": [],
    "bcc": []
  }
}
