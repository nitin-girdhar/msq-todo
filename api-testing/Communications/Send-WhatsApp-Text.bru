meta {
  name: Send WhatsApp Text Message
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/communications/whatsapp/text
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "phone_numbers": ["+919876543210"],
    "message": "Hello! This is a test message from CRM."
  }
}
