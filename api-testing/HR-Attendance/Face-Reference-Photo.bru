meta {
  name: Face Reference Photo
  type: http
  seq: 23
}

get {
  url: {{baseUrl}}/hr/attendance/face/reference/{{userId}}
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Streams the enrolled reference image (authenticated; same view authority as
  face status). Used by the review UI alongside the punch photo. 404 if unenrolled.
}
