meta {
  name: Reject Face Review
  type: http
  seq: 27
}

post {
  url: {{baseUrl}}/hr/attendance/face-reviews/{{attendanceEventId}}/reject
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Marks the punch 'rejected' AND invalidates it for attendance: the user's
  attendance_days for that date is recomputed excluding rejected events. Same
  approval authority as regularizations.
}
