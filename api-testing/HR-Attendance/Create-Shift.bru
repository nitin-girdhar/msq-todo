meta {
  name: Create Shift
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/hr/shifts
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "name": "Day",
    "start_time": "09:00",
    "end_time": "18:00",
    "grace_minutes": 10,
    "min_half_day_minutes": 240,
    "min_full_day_minutes": 480,
    "is_night_shift": false
  }
}
