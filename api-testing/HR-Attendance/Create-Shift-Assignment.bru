meta {
  name: Create Shift Assignment
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/hr/shift-assignments
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "user_id": "{{targetUserId}}",
    "shift_id": "{{shiftId}}",
    "effective_from": "2026-01-01"
  }
}
