meta {
  name: List Face Reviews
  type: http
  seq: 25
}

get {
  url: {{baseUrl}}/hr/attendance/face-reviews?status=pending&page=1&limit=20
  body: none
  auth: none
}

params:query {
  status: pending
  page: 1
  limit: 20
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Flagged punches for the approver's scope (manager subtree, or whole org for
  hr_admin/org_admin). status ∈ pending | cleared | rejected. Each row includes
  the punch photo key, reference photo key, score, user, and timestamp.
}
