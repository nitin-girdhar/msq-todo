meta {
  name: Update Rules (admin)
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/hr/attendance/rules/admin
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "geofence_enabled": true,
    "geofence_radius_meters": 200,
    "require_photo": true,
    "require_geo": true,
    "allow_wfh_checkin": false
  }
}
