meta {
  name: Face Enroll
  type: http
  seq: 21
}

post {
  url: {{baseUrl}}/hr/attendance/face/enroll
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "user_id": "{{userId}}",
    "consent": true,
    "photo": "/9j/4AAQSkZJRgABAQEAYABgAAD/2wBDAAgGBgcGBQgHBwcJCQgKDBQNDAsLDBkSEw8UHRofHh0aHBwgJC4nICIsIxwcKDcpLDAxNDQ0Hyc5PTgyPC4zNDL/wAALCAABAAEBAREA/8QAFAABAAAAAAAAAAAAAAAAAAAAAv/EABQQAQAAAAAAAAAAAAAAAAAAAAD/2gAIAQEAAD8AfwD/2Q=="
  }
}

docs {
  hr_admin/org_admin only. `consent` MUST be true (DPDP) — false returns 422
  FACE_CONSENT_REQUIRED. subject id === user UUID; re-enrolling replaces faces.
}
