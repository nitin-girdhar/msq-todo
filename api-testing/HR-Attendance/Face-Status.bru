meta {
  name: Face Status
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/hr/attendance/face/status/{{userId}}
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Enrollment status for UI badges. Viewable by self, subtree manager, or
  hr_admin/org_admin. Returns { enrolled, face_enrolled_at, face_consent_at, ... }.
}
