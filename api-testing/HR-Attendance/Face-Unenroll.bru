meta {
  name: Face Unenroll
  type: http
  seq: 24
}

delete {
  url: {{baseUrl}}/hr/attendance/face/enroll/{{userId}}
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  hr_admin/org_admin only. Drops the CompreFace subject and clears
  reference_photo_url / face_subject_id / face_enrolled_at / face_consent_at.
  Run as part of the employee-exit ops checklist (see docs/FACE_VERIFICATION.md).
}
