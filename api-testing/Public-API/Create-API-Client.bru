meta {
  name: Create API Client (Tenant Admin)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api-clients
  body: json
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

body:json {
  {
    "name": "Acme Partner - lead intake",
    "scopes": ["leads:write"],
    "rate_limit_per_min": 120,
    "org_ids": ["{{orgId}}"]
  }
}

docs {
  Requires an org_admin, tenant_admin, or super_admin session. The response
  contains `api_key` exactly once — copy it into the `apiClientKey` environment
  var to run the public endpoints below.

  Branch scoping: pass `org_ids` (array) to bind the key to specific branches,
  or `scope_all_orgs: true` for a tenant-wide key (then supply `branch_id` when
  creating leads/reading branches/users). For an org_admin caller, both fields
  are ignored server-side — the key is always forced to the caller's own
  branch.
}
