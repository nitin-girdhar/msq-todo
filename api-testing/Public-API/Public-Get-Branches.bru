meta {
  name: Public Get Branches (Partner API)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/public/v1/branches
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{apiClientKey}}
}

docs {
  Requires a key with `branches:read`. Returns tenant branches (id, name,
  brand_name, city, timezone, is_active). A tenant-wide key may narrow with
  ?branch_id=<uuid>; a branch-bound key is fixed to its branch.
}
