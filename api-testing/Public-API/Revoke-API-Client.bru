meta {
  name: Revoke API Client
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api-clients/{{apiClientId}}
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Deactivates the key immediately (is_active=false, revoked_at set). Subsequent
  public API calls with it return 401.
}
