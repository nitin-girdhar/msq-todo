meta {
  name: List API Clients
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api-clients
  body: none
  auth: none
}

headers {
  Cookie: auth_token={{authToken}}
}

docs {
  Lists API clients visible to the caller (prefix + metadata only — the key
  hash is never returned). org_admin sees only clients bound to their own
  branch; tenant_admin/super_admin see every client in the tenant.
}
