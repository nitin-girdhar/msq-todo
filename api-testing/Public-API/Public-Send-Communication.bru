meta {
  name: Public Send Communication (Partner API)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/public/v1/communications/send
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{apiClientKey}}
}

body:json {
  {
    "phone_numbers": ["9876543210"],
    "template_name": "appointment_reminder",
    "language_code": "en",
    "body_values": ["Tomorrow 5pm"]
  }
}

docs {
  Requires a key with `comms:send`. Recipients must resolve to a CRM user or lead
  in the key's tenant, otherwise the request is rejected (400 with the unknown
  recipients). Approved WhatsApp templates work with `comms:send`; free-form
  bodies (email, or WhatsApp `message` without a template) additionally require
  the `comms:send:adhoc` scope.
}
