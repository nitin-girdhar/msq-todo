{
  "name": "platform-todo-repo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint depcruise",
    "depcruise": "depcruise packages services apps",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "stop": "taskkill /F /IM node.exe 2>nul || echo No node processes found",
    "predev": "pnpm stop",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "dependency-cruiser": "^18.1.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
