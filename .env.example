# ─────────────────────────────────────────────────────────────────────────────
# Shared across all backend services
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection components ──────────────────────────────────────────
# Change these to point at your Postgres instance. docker-compose.yml reads
# these variables too, so one edit here updates everything.
DB_NAME=crm
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Passw0rd

# Docker container name (used by docker-compose as the network hostname)
DB_CONTAINER_NAME=crm-db-server

# Host path for Postgres data (persistent across container recreates)
DB_DATA_PATH=C:/Girdhar/database_files

# Service-role credentials (created by 01_init-db.sql)
DB_LEAD_SVC_USER=lead_svc
DB_LEAD_SVC_PASSWORD=LeadSvc_Dev2025
DB_TENANT_SVC_USER=tenant_dash_svc
DB_TENANT_SVC_PASSWORD=TenantSvc_Dev2025
DB_SERVICE_USER=crm_service
DB_SERVICE_PASSWORD=CrmSvc_Dev2025

# ── Composed DATABASE_URLs (local dev — services outside Docker) ─────────────
# These use DB_HOST (localhost). docker-compose overrides them with the
# container hostname so you never need to touch docker-compose.yml.
DATABASE_URL=postgres://lead_svc:LeadSvc_Dev2025@localhost:5432/crm
DATABASE_URL_TENANT=postgres://tenant_dash_svc:TenantSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://crm_service:CrmSvc_Dev2025@localhost:5432/crm

# PostgreSQL pool tuning
PG_MAX=10
PG_IDLE_TIMEOUT=30

# PostgreSQL SSL (production)
PG_SSL_MODE=disable             # Force SSL off (local dev, Docker network)
# PG_SSL_CA_PATH=/path/to/ca.pem  # Path to CA certificate file
# PG_SSL_CA=                    # Inline CA certificate (alternative to PG_SSL_CA_PATH)

# JWT
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_SECRET must be the SAME value across all services that verify tokens

# Asymmetric JWT signing (RS256). When set, tokens are signed RS256 and other apps
# can verify them via GET /.well-known/jwks.json without any shared secret. When
# unset, signing/verification falls back to the HS256 JWT_SECRET above.
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#           openssl rsa -in priv.pem -pubout -out pub.pem
# Store PEMs with literal \n escapes on a single line, or as real multiline values.
# JWT_KID=2026-key-1
# JWT_PRIVATE_KEY=   # identity-service only (signing)
# JWT_PUBLIC_KEY=    # api-gateway + identity-service (verification / JWKS)

# Inter-service authentication — gateway injects this header, services reject without it
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string

# API key for the intake webhook endpoint (pre-shared with ad platform integrations)
WEBHOOK_API_KEY=change-me-webhook-key

# Server-side pepper for hashing public/partner API keys (ext.api_clients).
# Must be identical in api-gateway and identity-service. REQUIRED in production.
# Generate: openssl rand -hex 32
PUBLIC_API_KEY_PEPPER=change-me-public-api-pepper

# Meta credential encryption (app_secret + page access_token stored at rest).
# 32-byte key as 64 hex chars or base64. REQUIRED in production; if unset in dev,
# Meta credentials are stored in plaintext. Generate: openssl rand -hex 32
# META_ENCRYPTION_KEY=

# Allow unsigned Meta webhooks (skips HMAC when no signature header is present).
# Must be false/unset in production; only for local testing without a real app secret.
ALLOW_UNSIGNED_WEBHOOKS=true

# ─────────────────────────────────────────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
IDENTITY_SERVICE_PORT=4001
LEADS_SERVICE_PORT=4002
META_SERVICE_PORT=4003
NOTIFICATIONS_SERVICE_PORT=4004
COMMUNICATION_SERVICE_PORT=4005
ADMIN_SERVICE_PORT=4006
HR_SERVICE_PORT=4007
TASKS_SERVICE_PORT=4008

# ─────────────────────────────────────────────────────────────────────────────
# Internal service URLs (used by api-gateway and inter-service calls)
# ─────────────────────────────────────────────────────────────────────────────
IDENTITY_SERVICE_URL=http://localhost:4001
LEADS_SERVICE_URL=http://localhost:4002
META_SERVICE_URL=http://localhost:4003
NOTIFICATIONS_SERVICE_URL=http://localhost:4004
COMMUNICATION_SERVICE_URL=http://localhost:4005
ADMIN_SERVICE_URL=http://localhost:4006
HR_SERVICE_URL=http://localhost:4007
TASKS_SERVICE_URL=http://localhost:4008
FOLLOWUP_CHECK_INTERVAL_MS=60000
FOLLOWUP_LOOKAHEAD_MINUTES=5

# ─────────────────────────────────────────────────────────────────────────────
# Attendance photo storage (hr-service). Punch selfies arrive as base64 in the
# JSON body (≤2 MB) and are written via a PhotoStorage driver, then re-served only
# through the authenticated GET /hr/attendance/photos/:id route.
# ─────────────────────────────────────────────────────────────────────────────
PHOTO_STORAGE_DRIVER=local
PHOTO_STORAGE_DIR=/data/attendance-photos
PHOTO_MAX_BYTES=2097152

# ─────────────────────────────────────────────────────────────────────────────
# Face verification (hr-service → self-hosted CompreFace, internal-only).
# CompreFace runs on the compose network with its OWN postgres (never the app DB)
# and is NEVER exposed publicly or proxied by the gateway. Only hr-service calls
# it. require_face_match is an opt-in per-org attendance rule; when off, none of
# this is exercised and the API key may stay blank.
#
# COMPREFACE_API_KEY is a Recognition-service key created once via the admin UI
# (create app → add a Recognition service → copy its key). See
# docs/FACE_VERIFICATION.md for the one-time setup steps.
# ─────────────────────────────────────────────────────────────────────────────
FACE_DRIVER=compreface
# Local dev (hr-service outside Docker) reaches CompreFace through the published
# admin-UI nginx (COMPREFACE_ADMIN_UI_PORT). docker-compose overrides this with the
# internal http://compreface-api:8080 so in-cluster traffic skips nginx entirely.
COMPREFACE_URL=http://localhost:8010
COMPREFACE_API_KEY=
FACE_VERIFY_TIMEOUT_MS=5000

# CompreFace's OWN database (separate container + volume from the app cluster).
COMPREFACE_POSTGRES_USER=compreface
COMPREFACE_POSTGRES_PASSWORD=change-me-compreface-db
COMPREFACE_POSTGRES_DB=compreface
# Ops-only: host port for the CompreFace admin UI (leave unset in prod). The UI
# is only needed for the one-time API-key setup; the API itself stays internal.
COMPREFACE_ADMIN_UI_PORT=8010

# ─────────────────────────────────────────────────────────────────────────────
# Communication service (email + WhatsApp)
# ─────────────────────────────────────────────────────────────────────────────
# SMTP / Email (all required for email to be enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Your App Name

# WhatsApp via Interakt (required for WhatsApp to be enabled)
INTERAKT_API_KEY=your-interakt-api-key
# INTERAKT_API_BASE_URL=https://api.interakt.ai/v1/public/

# ─────────────────────────────────────────────────────────────────────────────
# Identity service (auth + users)
# ─────────────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Minimum length enforced for new/changed passwords (identity-service policy).
PASSWORD_MIN_LENGTH=12

# ─────────────────────────────────────────────────────────────────────────────
# App environment
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Web app (Next.js — apps/web)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# JWT_SECRET must also be set for middleware.ts Edge JWT validation

# Must match PASSWORD_MIN_LENGTH above — drives the password-strength checklist
# shown in the change-password / reset-password forms.
NEXT_PUBLIC_PASSWORD_MIN_LENGTH=12

# Gateway
WEB_URL=http://localhost:3000
