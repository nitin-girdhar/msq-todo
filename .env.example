# ─────────────────────────────────────────────────────────────────────────────
# To-Do / Tasks product (msq-todo) — tasks-service, todo-web.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection (shared cluster — see msq-core) ──────────────────
DB_NAME=crm
DB_HOST=localhost
DB_PORT=5432
DB_CONTAINER_NAME=crm-db-server

# Per-product DB login role (P1.2/D8, created by db_scripts/19). Reads/writes
# only task + read-only iam/entity/geo.
DB_TASK_SVC_USER=task_svc
DB_TASK_SVC_PASSWORD=TaskSvc_Dev2025
DB_SERVICE_USER=root_service
DB_SERVICE_PASSWORD=CrmSvc_Dev2025

DATABASE_URL=postgres://task_svc:TaskSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm
DB_PRODUCT_SCOPED_LOGIN=true

PG_MAX=10
PG_IDLE_TIMEOUT=30
PG_SSL_MODE=disable

# ── Auth (must match msq-core's identity-service exactly) ─────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_PUBLIC_KEY=    # RS256 verification — preferred over JWT_SECRET
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string

# ─────────────────────────────────────────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────────────────────────────────────────
TASKS_SERVICE_PORT=4008

# ── Internal service URLs (this repo's service + the shared gateway) ────────
# Port msq-core's api-gateway listens on — docker-compose composes the gateway
# URL from it, so it must match msq-core's GATEWAY_PORT.
GATEWAY_PORT=4000
API_GATEWAY_INTERNAL_URL=http://localhost:4000
TASKS_SERVICE_URL=http://localhost:4008

NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# todo-web (Next.js) → todo.app.com
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_LMS_URL=http://localhost:3001
NEXT_PUBLIC_HR_URL=http://localhost:3002
NEXT_PUBLIC_TASK_URL=http://localhost:3003
NEXT_PUBLIC_PASSWORD_MIN_LENGTH=12
COOKIE_SECURE=false
